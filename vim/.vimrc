set nocompatible
syntax on
filetype plugin indent on

set number
set relativenumber
set cursorline
set hidden
set incsearch
set ignorecase
set smartcase
set hlsearch
set wildmenu
set showcmd
set showmode
set backspace=indent,eol,start
set tabstop=2
set shiftwidth=2
set expandtab
set smartindent
set undofile

let mapleader = " "
nnoremap <leader>w :w<CR>
nnoremap <leader>q :q<CR>
